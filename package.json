{
  "name": "little-coder",
  "version": "1.8.1",
  "description": "A pi-based coding agent optimized for small local language models. Reproduces the whitepaper's scaffold-model-fit adaptations as pi extensions.",
  "homepage": "https://github.com/L3tum/little-coder",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/L3tum/little-coder.git"
  },
  "bugs": {
    "url": "https://github.com/L3tum/little-coder/issues"
  },
  "license": "Apache-2.0",
  "author": "L3tum",
  "type": "module",
  "littleCoder": {
    "packages": [
      "@plannotator/pi-extension",
      "@juicesharp/rpiv-todo",
      "pi-better-openai"
    ]
  },
  "bin": {
    "little-coder": "bin/little-coder.mjs"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "files": [
    "bin/",
    "AGENTS.md",
    "skills/",
    ".pi/extensions/",
    ".pi/settings.json",
    "models.json",
    "LICENSE",
    "NOTICE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "pi": "pi",
    "test": "vitest run",
    "test:py": "python3 -m pytest benchmarks/test_rpc_client.py -q",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.74.1",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@earendil-works/pi-tui": "^0.74.1",
    "@juicesharp/rpiv-todo": "^1.11.0",
    "@plannotator/pi-extension": "^0.19.20",
    "@sinclair/typebox": "^0.34.49",
    "chokidar": "^5.0.0",
    "glob": "^13.0.6",
    "open": "^11.0.0",
    "pi-better-openai": "^0.1.18",
    "pi-inspect": "^0.5.0",
    "pi-powerline-footer": "^0.5.4",
    "playwright": "^1.59.1",
    "typebox": "^1.1.38",
    "vscode-languageserver-protocol": "^3.17.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "optionalDependencies": {
    "@tobilu/qmd": "^2.5.2"
  }
}
